{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "telegram-voice-transcriber",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-07",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "DAILY_BUDGET",
        "class_name": "DailyBudget"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DailyBudget"]
    }
  ],
  "vars": {
    "ALLOW_PRIVATE_CHATS": "false",
    "ALLOWED_CHAT_IDS": "",
    "DAILY_TRANSCRIPTION_SECONDS": "6000",
    "DEFAULT_LANGUAGE": "uk",
    "MAX_FILE_SIZE_BYTES": "20000000",
    "MAX_DURATION_SECONDS": "300",
    "WHISPER_MODEL": "@cf/openai/whisper-large-v3-turbo"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
